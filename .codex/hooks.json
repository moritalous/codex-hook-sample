{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/session_start.sh\""
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/user_prompt_submit.sh\""
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/stop.sh\""
                    }
                ]
            }
        ]
    }
}
